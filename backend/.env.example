# ============================
# 🔌 MySQL 資料庫連線（請填入）
# ============================
DATABASE_URL=mysql+pymysql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DBNAME>

# Aiven 範例：
# DATABASE_URL=mysql+pymysql://avnadmin:yourpassword@mysql-xxx.aivencloud.com:12345/defaultdb

# Render 範例：
# DATABASE_URL=mysql+pymysql://root:yourpassword@mysql-xxx.render.com:3306/stock_db

# 本地開發範例：
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/stock_backtest

# ============================
# 其他設定
# ============================
FINMIND_TOKEN=
DISCORD_WEBHOOK_URL=
GEMINI_API_KEY=
OPENAI_API_KEY=
FRONTEND_URL=http://localhost:5173
